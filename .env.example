# ============================================================
# ERP FRONERI - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no git
# ============================================================

# Servidor
NODE_ENV=production
PORT=3001

# Banco de Dados PostgreSQL (KingHost)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=erp_froneri
DB_USER=erp_froneri_user
DB_PASSWORD=SUA_SENHA_SEGURA_AQUI
DB_SSL=false

# JWT (gere uma chave aleatória: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=GERE_UMA_CHAVE_ALEATORIA_DE_64_BYTES_AQUI
JWT_EXPIRES_IN=8h

# CORS - domínio do seu frontend
CORS_ORIGIN=https://erp.seudominio.com.br

# Upload de arquivos
UPLOAD_MAX_SIZE_MB=50
UPLOAD_DIR=./uploads

# Logs
LOG_LEVEL=info
