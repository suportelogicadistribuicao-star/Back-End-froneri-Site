# Servidor
NODE_ENV=production
PORT=8080

# Banco de Dados MySQL
DB_HOST=seu-host-mysql
DB_PORT=3306
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASSWORD=sua_senha_forte
DB_SSL=false
DB_SLOW_QUERY_MS=1500

# JWT
JWT_SECRET=gere_uma_chave_aleatoria_forte
JWT_EXPIRES_IN=8h

# CORS
CORS_ORIGIN=https://seu-frontend.com

# Upload
UPLOAD_MAX_SIZE_MB=50
UPLOAD_DIR=./uploads
