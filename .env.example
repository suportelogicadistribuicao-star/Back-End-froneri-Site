# Servidor
NODE_ENV=production
PORT=8080

# Banco de Dados MySQL
DB_HOST=seu-host-mysql
DB_PORT=3306
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASSWORD=sua_senha_forte
DB_SSL=false
DB_SLOW_QUERY_MS=1500

# JWT
JWT_SECRET=gere_uma_chave_aleatoria_forte
JWT_EXPIRES_IN=8h

# CORS (aceita múltiplas origens separadas por vírgula)
CORS_ORIGIN=https://seu-frontend.com,https://www.seu-frontend.com

# Upload
UPLOAD_MAX_SIZE_MB=50
UPLOAD_DIR=./uploads
UPLOAD_STALE_MINUTES=60

# Backblaze B2 (upload de relatórios via URL pré-assinada — evita bloqueio de multipart da KingHost)
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_KEY_ID=sua_key_id_b2
B2_APPLICATION_KEY=sua_application_key_b2
B2_BUCKET_NAME=froneri-imports
B2_PRESIGN_EXPIRES_SECONDS=300
