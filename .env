# ============================================================
# ERP FRONERI - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no git
# ============================================================

# Servidor
NODE_ENV=Production
PORT=21062

# Banco de Dados MySQL
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=erp_froneri
# DB_USER=root
# DB_PASSWORD=sua_senha
# DB_SSL=false

DB_HOST=mysql.web-ded-185905a.kinghost.net
DB_PORT=3306
DB_NAME=logicadistribu
DB_USER=logicadistribu
DB_PASSWORD=logica2026
DB_SSL=false


B2_ENDPOINT=https://s3.<sua-regiao>.backblazeb2.com
B2_REGION=<sua-regiao>
B2_KEY_ID=<keyID da Application Key>
B2_APPLICATION_KEY=<applicationKey>
B2_BUCKET_NAME=<nome do seu bucket>
B2_PRESIGN_EXPIRES_SECONDS=300



# JWT (gere uma chave aleatória: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=GERE_UMA_CHAVE_ALEATORIA_DE_64_BYTES_AQUI
JWT_EXPIRES_IN=8h

# CORS - domínio do seu frontend
CORS_ORIGIN=*

# Upload de arquivos
UPLOAD_MAX_SIZE_MB=50
UPLOAD_DIR=./uploads

# Logs
LOG_LEVEL=info
