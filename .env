# ============================================================
# ERP FRONERI - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no git
# ============================================================

# Servidor
NODE_ENV=development
PORT=8080

# Banco de Dados MySQL
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=erp_froneri
# DB_USER=root
# DB_PASSWORD=sua_senha
# DB_SSL=false

DB_HOST=localhost
DB_PORT=3306
DB_NAME=erp_froneri
DB_USER=root
DB_PASSWORD=sua_senha
DB_SSL=false

# JWT (gere uma chave aleatória: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=GERE_UMA_CHAVE_ALEATORIA_DE_64_BYTES_AQUI
JWT_EXPIRES_IN=8h

# CORS - domínio do seu frontend
CORS_ORIGIN=*

# Upload de arquivos
UPLOAD_MAX_SIZE_MB=50
UPLOAD_DIR=./uploads

# Logs
LOG_LEVEL=info
